# Flask
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Database
DATABASE_URL=sqlite:///instance/database.db

# API Keys
SSSTIK_COOKIE=your-ssstik-cookie-here

# Features
ENABLE_BATCH_DOWNLOAD=True
ENABLE_4K_UPSCALE=True
ENABLE_USER_SYSTEM=True

# Limits
MAX_DOWNLOADS_PER_HOUR=50
MAX_DOWNLOADS_PER_DAY=200
FILE_RETENTION_HOURS=24
QUEUE_MAX_SIZE=100

# Default Settings
DEFAULT_QUALITY=4K
DEFAULT_API=tikwm
DEFAULT_UPSCALE_METHOD=lanczos

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0
